# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/refund_auditor"

# ─── Firebase (Client SDK — public, safe to expose) ───────────────────────────
# From Firebase Console → Project Settings → Your apps → Web app → Config
NEXT_PUBLIC_FIREBASE_API_KEY="AIza..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123:web:abc"

# ─── Firebase Admin (Server SDK — secret, never expose) ───────────────────────
# From Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
# Keep the \n escape sequences — they will be replaced at runtime
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# Session cookie — generate with: openssl rand -base64 32
SESSION_SECRET="your-session-secret-here"

# ─── Token Encryption (AES-256-GCM) ───────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here"

# ─── Amazon SP-API ────────────────────────────────────────────────────────────
# From your Amazon Developer Central app registration:
# https://developer.amazon.com/apps/manage
AMAZON_APP_ID="amzn1.sp.solution.xxxxxxxx"
AMAZON_CLIENT_ID="amzn1.application-oa2-client.xxxxxxxx"
AMAZON_CLIENT_SECRET="your-lwa-client-secret"

# Callback URL registered in your Seller Central developer app
AMAZON_REDIRECT_URI="http://localhost:3000/api/accounts/callback"

# SP-API region endpoints:
#   NA: https://sellingpartnerapi-na.amazon.com
#   EU: https://sellingpartnerapi-eu.amazon.com
#   FE: https://sellingpartnerapi-fe.amazon.com
AMAZON_API_ENDPOINT="https://sellingpartnerapi-na.amazon.com"

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── AWS (for SP-API Notifications → SQS) ─────────────────────────────────────
# Required only if you want automatic buyer message capture via SP-API Notifications.
# 1. Create an SQS Standard queue in your AWS account.
# 2. Add a queue policy that allows Amazon (principal: "arn:aws:iam::437568002678:root")
#    to send messages to it.  See SP-API Notifications docs for the exact policy.
# 3. Set the values below and call POST /api/messaging/subscribe to activate.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
# SQS Queue ARN (used when registering the SP-API destination)
SQS_QUEUE_ARN="arn:aws:sqs:us-east-1:123456789012:amazon-notifications"
# SQS Queue URL (used when polling for messages)
SQS_QUEUE_URL="https://sqs.us-east-1.amazonaws.com/123456789012/amazon-notifications"
