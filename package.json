{
  "name": "open-line-mobility",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "node scripts/patch-qz-tray.js",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:seed-account": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-account.ts",
    "backfill:fulfillment": "curl -s -X POST http://localhost:3000/api/admin/backfill-fulfillment -H \"x-cron-secret: $CRON_SECRET\" | jq .",
    "db:studio": "prisma studio",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1000.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@prisma/client": "^5.10.0",
    "@tanstack/react-table": "^8.13.0",
    "@vercel/functions": "^3.4.3",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "csv-stringify": "^6.4.6",
    "date-fns": "^3.3.1",
    "firebase": "^10.8.0",
    "firebase-admin": "^12.0.0",
    "js-cookie": "^3.0.5",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.323.0",
    "next": "14.1.0",
    "qz-tray": "^2.2.5",
    "react": "^18.2.0",
    "react-datepicker": "^6.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.50.1",
    "sonner": "^1.4.0",
    "tailwind-merge": "^2.2.1",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/js-cookie": "^3.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.17",
    "@types/react": "^18.2.55",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^18.2.19",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.1.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "postcss": "^8.4.35",
    "prisma": "^5.10.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
