// ─── Prisma Schema ────────────────────────────────────────────────────────────
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  firebaseUid  String?  @unique // set after first Firebase login
  passwordHash String? // unused with Firebase auth; kept for legacy seed
  name         String
  role         UserRole @default(REVIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastSeenAt   DateTime?

  reviews     Review[]
  auditEvents AuditEvent[]


  chatConversations1 ChatConversation[] @relation("ChatUser1")
  chatConversations2 ChatConversation[] @relation("ChatUser2")
  chatMessagesSent   ChatMessage[]
  serialHistoryEvents SerialHistory[]
  clientLocationAccess ClientLocationAccess[]
  companyName          String?
  clientNotes          ClientNote[]

  casesCreated    Case[]           @relation("CaseCreatedBy")
  casesResolved   Case[]           @relation("CaseResolvedBy")
  caseTaggedUsers CaseTaggedUser[]
  caseMessages    CaseMessage[]

  visibleUsers       ResolutionProviderVisibility[] @relation("ResProviderVisibility")
  visibleToProviders ResolutionProviderVisibility[] @relation("ResProviderVisibleTo")

  canAccessOli          Boolean  @default(false)
  canViewPurchaseOrders Boolean  @default(false)
  vendorId              String?
  vendor                Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  fbaReturnReceipts     FbaReturnReceipt[]

  @@map("users")
}

model ClientLocationAccess {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, locationId])
  @@map("client_location_access")
}

model ClientNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@map("client_notes")
}

// ─── Amazon Accounts ──────────────────────────────────────────────────────────

model AmazonAccount {
  id              String   @id @default(cuid())
  sellerId        String // Amazon Seller ID (e.g. A1B2C3D4E5F6)
  marketplaceId   String // e.g. ATVPDKIKX0DER for US
  marketplaceName String // e.g. "Amazon.com"
  region          String   @default("NA") // NA | EU | FE
  // Encrypted LWA tokens (AES-256-GCM, stored as "iv:authTag:ciphertext")
  accessTokenEnc  String
  refreshTokenEnc String
  tokenExpiresAt  DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  refunds           Refund[]
  importJobs        ImportJob[]
  sellerListings    SellerListing[]
  listingSyncJobs   ListingSyncJob[]
  templateBatchJobs TemplateBatchJob[]
  competitiveOffers CompetitiveOffer[]
  orders            Order[]
  orderSyncJobs     OrderSyncJob[]
  mfnReturns        MFNReturn[]
  mfnReturnSyncJobs MFNReturnSyncJob[]
  fbaRefunds        FbaRefund[]
  fbaReturns        FbaReturn[]
  fbaReimbursements FbaReimbursement[]
  fbaShipments      FbaShipment[]
  freeReplacements  FreeReplacement[]

  @@unique([sellerId, marketplaceId])
  @@map("amazon_accounts")
}

// ─── Import Jobs ──────────────────────────────────────────────────────────────

model ImportJob {
  id            String          @id @default(cuid())
  accountId     String
  account       AmazonAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  startDate     DateTime
  endDate       DateTime
  status        ImportJobStatus @default(PENDING)
  totalFound    Int             @default(0)
  totalUpserted Int             @default(0)
  errorMessage  String?
  startedAt     DateTime        @default(now())
  completedAt   DateTime?

  @@map("import_jobs")
}

// ─── Refunds ──────────────────────────────────────────────────────────────────

model Refund {
  id        String        @id @default(cuid())
  accountId String
  account   AmazonAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Natural key from SP-API
  orderId      String // Amazon order ID
  adjustmentId String // ShipmentItemAdjustment.AdjustmentId (unique per refund line)

  // Core fields
  postedDate      DateTime
  amount          Decimal         @db.Decimal(12, 2)
  currency        String          @default("USD")
  fulfillmentType FulfillmentType @default(UNKNOWN)
  marketplaceId   String
  sku             String?
  asin            String?
  productTitle    String? // Fetched from Catalog Items API
  reasonCode      String? // Refund reason from SP-API if available

  // Full raw payload for the audit trail
  rawPayload Json

  importedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  review      Review?
  auditEvents AuditEvent[]

  // Prevent duplicate imports for the same refund line item
  @@unique([accountId, orderId, adjustmentId])
  @@index([postedDate])
  @@index([fulfillmentType])
  @@index([accountId])
  @@map("refunds")
}

enum FbaValidationStatus {
  UNVALIDATED
  VALIDATED
  MANUAL_REVIEW
}

// ─── FBA Refunds (standalone, no review workflow) ────────────────────────────

model FbaRefund {
  id                String        @id @default(cuid())
  accountId         String
  account           AmazonAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  orderId           String        // Amazon order ID
  adjustmentId      String        // OrderAdjustmentItemId — unique per refund line
  sku               String?
  fnsku             String?       // Fulfillment Network SKU
  asin              String?
  title             String?
  refundAmount      Decimal       @db.Decimal(12, 2)
  currency          String        @default("USD")
  refundQty         Int           @default(1)
  refundDate        DateTime
  originalOrderDate DateTime?     // Joined from Orders table
  marketplaceId     String

  rawPayload        Json

  validationStatus  FbaValidationStatus @default(UNVALIDATED)
  validatedAt       DateTime?
  validationReason  String?
  validationSource  String?

  importedAt        DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([accountId, orderId, adjustmentId])
  @@index([refundDate])
  @@index([accountId])
  @@index([validationStatus])
  @@map("fba_refunds")
}

// ─── FBA Returns (Customer Returns Report) ───────────────────────────────────

model FbaReturn {
  id                  String        @id @default(cuid())
  accountId           String
  account             AmazonAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  orderId             String
  sku                 String        @default("") // non-null for composite unique dedup
  fnsku               String?
  asin                String?
  title               String?
  quantity            Int?
  returnDate          DateTime?
  status              String?       // e.g. "Unit returned to inventory"
  statusChangeDate    DateTime?
  detailedDisposition String?       // e.g. "SELLABLE", "DAMAGED"
  fulfillmentCenterId String?
  lpn                 String?       // License Plate Number

  importedAt          DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([accountId, orderId, sku])
  @@index([orderId])
  @@index([accountId])
  @@map("fba_returns")
}

// ─── FBA Reimbursements ──────────────────────────────────────────────────────

model FbaReimbursement {
  id                          String        @id @default(cuid())
  accountId                   String
  account                     AmazonAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  reimbursementId             String        // Amazon's reimbursement-id
  orderId                     String?       // amazon-order-id (may be empty for some types)
  caseId                      String?
  reason                      String?       // e.g. "CUSTOMER_RETURN", "Damaged_Warehouse"
  sku                         String        @default("") // non-null for composite unique dedup
  fnsku                       String?
  asin                        String?
  title                       String?
  condition                   String?
  currencyUnit                String?       @default("USD")
  amountPerUnit               Decimal?      @db.Decimal(12, 2)
  amountTotal                 Decimal?      @db.Decimal(12, 2)
  quantityReimbursedCash      Int?
  quantityReimbursedInventory Int?
  quantityReimbursedTotal     Int?
  approvalDate                DateTime?

  importedAt                  DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt

  @@unique([accountId, reimbursementId, sku])
  @@index([orderId])
  @@index([accountId])
  @@map("fba_reimbursements")
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id       String @id @default(cuid())
  refundId String @unique
  refund   Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)

  status        ReviewStatus   @default(UNREVIEWED)
  invalidReason InvalidReason?
  customReason  String? // Required when invalidReason = OTHER
  notes         String?

  reviewedById String?
  reviewedBy   User?     @relation(fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}

// ─── Audit Events ─────────────────────────────────────────────────────────────

model AuditEvent {
  id         String @id @default(cuid())
  entityType String // "Review" | "Import" | "Account"
  entityId   String
  action     String // "REVIEW_UPDATED" | "BULK_REVIEW" | "IMPORT_STARTED" | etc.
  before     Json?
  after      Json?

  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  actorLabel String // display: email or "system"
  timestamp  DateTime @default(now())

  // Optional FK for quick refund-scoped queries
  refundId String?
  refund   Refund? @relation(fields: [refundId], references: [id])

  @@index([timestamp])
  @@index([entityType, entityId])
  @@index([refundId])
  @@map("audit_events")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  REVIEWER
  CLIENT
  RESOLUTION_PROVIDER
  VENDOR
}

enum FulfillmentType {
  FBA // Fulfilled by Amazon (AFN)
  MFN // Merchant Fulfilled
  UNKNOWN
}

enum ReviewStatus {
  UNREVIEWED
  VALID
  INVALID
}

enum InvalidReason {
  DIFFERENT_ITEM_RETURNED
  RETURN_NEVER_RECEIVED
  OUTSIDE_POLICY_WINDOW
  WRONG_SKU_ASIN
  DUPLICATE_REFUND
  SHIPPING_NOT_RETURNED
  CHARGEBACK_RELATED
  OTHER
}

enum ImportJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ─── Seller Listings ──────────────────────────────────────────────────────────

model SellerListing {
  id               String        @id @default(cuid())
  accountId        String
  account          AmazonAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sku              String
  asin             String?
  productTitle     String?
  shippingTemplate String?
  listingStatus    String?
  quantity         Int           @default(0)
  price            Decimal?      @db.Decimal(12, 2)
  lastSyncedAt     DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  condition          String? // e.g. "New", "Used - Like New", etc.
  groupName          String? // local organizational group, not synced to Amazon
  fulfillmentChannel String   @default("MFN") // MFN = merchant fulfilled, FBA = fulfilled by Amazon
  minPrice           Decimal? @db.Decimal(12, 2)
  maxPrice           Decimal? @db.Decimal(12, 2)

  fnsku              String?   // Fulfillment Network SKU (from fulfillment-channel-sku TSV column)
  productType        String?   // Amazon productType (e.g. CELLULAR_PHONE), cached from SP-API

  sold24h            Int       @default(0)
  sold3d             Int       @default(0)
  sold7d             Int       @default(0)
  velocitySyncedAt   DateTime?

  @@unique([accountId, sku])
  @@index([accountId])
  @@index([shippingTemplate])
  @@index([accountId, groupName])
  @@index([accountId, fulfillmentChannel])
  @@map("seller_listings")
}

model ListingSyncJob {
  id            String               @id @default(cuid())
  accountId     String
  account       AmazonAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  status        ListingSyncJobStatus @default(PENDING)
  totalFound    Int                  @default(0)
  totalUpserted Int                  @default(0)
  errorMessage  String?
  startedAt     DateTime             @default(now())
  completedAt   DateTime?

  @@map("listing_sync_jobs")
}

enum ListingSyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ─── Template Batch Jobs ──────────────────────────────────────────────────────
// Tracks background bulk shipping-template updates so the UI stays responsive.

model TemplateBatchJob {
  id           String                 @id @default(cuid())
  accountId    String
  account      AmazonAccount          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  templateName String
  totalSkus    Int
  processed    Int                    @default(0)
  updated      Int                    @default(0)
  failedSkus   Json // Array<{ sku: string; error: string }>
  status       TemplateBatchJobStatus @default(RUNNING)
  errorMessage String?
  startedAt    DateTime               @default(now())
  completedAt  DateTime?

  @@map("template_batch_jobs")
}

enum TemplateBatchJobStatus {
  RUNNING
  COMPLETED
  FAILED
}

// ─── Seller Name Cache ────────────────────────────────────────────────────────
// Seller names are not returned by Amazon's SP-API; they are resolved once by
// fetching the public Amazon seller profile page and cached permanently.
// name=null means a fetch was attempted but the name could not be parsed.

model SellerProfile {
  sellerId  String   @id
  name      String?
  fetchedAt DateTime @default(now())

  @@map("seller_profiles")
}

// ─── Competitive Offers ───────────────────────────────────────────────────────
// One row per competing offer observed for an ASIN.  Refreshed after every
// catalog sync via the SP-API Product Pricing batch endpoint.
// Note: Amazon's API does not expose competitor seller names — sellerId is the
// best available identifier for third-party sellers.

model CompetitiveOffer {
  id              String        @id @default(cuid())
  accountId       String
  account         AmazonAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  asin            String
  sellerId        String
  isMyOffer       Boolean       @default(false) // true when offer belongs to this account
  fulfillmentType String // "FBA" | "MFN"
  listingPrice    Decimal       @db.Decimal(12, 2)
  shippingPrice   Decimal       @default(0) @db.Decimal(12, 2)
  landedPrice     Decimal       @db.Decimal(12, 2)
  isPrime         Boolean       @default(false)
  isBuyBoxWinner  Boolean       @default(false)
  condition       String        @default("new")
  feedbackRating  Decimal?      @db.Decimal(5, 2) // seller positive feedback %
  feedbackCount   Int? // number of feedback ratings
  lastFetchedAt   DateTime      @default(now())

  @@unique([accountId, asin, sellerId, fulfillmentType])
  @@index([accountId, asin])
  @@map("competitive_offers")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

enum OrderWorkflowStatus {
  PENDING // Downloaded from Amazon, not yet processed
  PROCESSING // Inventory reserved, ready to ship
  AWAITING_VERIFICATION // Label purchased; awaiting serialization and verification
  SHIPPED // Verified and shipped
  CANCELLED // Manually cancelled; any reservations have been released
}

model Order {
  id                     String                      @id @default(cuid())
  olmNumber              Int?                        @unique
  accountId              String
  account                AmazonAccount               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  amazonOrderId          String
  orderStatus            String
  workflowStatus         OrderWorkflowStatus         @default(PENDING)
  processedAt            DateTime?
  purchaseDate           DateTime
  lastUpdateDate         DateTime
  orderTotal             Decimal?                    @db.Decimal(12, 2)
  currency               String?                     @default("USD")
  fulfillmentChannel     String?
  shipmentServiceLevel   String?
  numberOfItemsUnshipped Int                         @default(0)
  shipToName             String?
  shipToAddress1         String?
  shipToAddress2         String?
  shipToCity             String?
  shipToState            String?
  shipToPostal           String?
  shipToCountry          String?
  shipToPhone            String?
  isPrime                Boolean                     @default(false)
  orderSource            String                      @default("amazon") // "amazon" | "backmarket"
  lastSyncedAt           DateTime                    @default(now())
  isBuyerRequestedCancel Boolean                     @default(false)
  buyerCancelReason      String?
  latestShipDate         DateTime?
  latestDeliveryDate     DateTime?
  presetRateAmount       Decimal?                    @db.Decimal(12, 2)
  presetRateCarrier      String?
  presetRateService      String?
  presetRateId           String?
  presetRateError        String?
  presetRateCheckedAt    DateTime?
  presetShipDate         String?
  appliedPresetId        String?
  appliedPreset          ShippingPreset?             @relation(fields: [appliedPresetId], references: [id], onDelete: SetNull)
  appliedPackagePresetId String?
  appliedPackagePreset   PackagePreset?              @relation(fields: [appliedPackagePresetId], references: [id], onDelete: SetNull)
  ssOrderId              Int?
  customerPo             String?
  shipCarrier            String?
  shipTracking           String?
  shippedAt              DateTime?
  items                  OrderItem[]
  reservations           OrderInventoryReservation[]
  label                  OrderLabel?
  serialAssignments      OrderSerialAssignment[]
  labelBatchItems        LabelBatchItem[]
  serialHistory          SerialHistory[]
  isReplacement          Boolean?
  replacedOrderId        String?
  manualShipCost         Decimal?                    @db.Decimal(12, 2)
  marketplaceCommission  Decimal?                    @db.Decimal(12, 2)
  fbaFulfillmentFee      Decimal?                    @db.Decimal(12, 2)
  commissionSyncedAt     DateTime?
  marketplaceRMAs        MarketplaceRMA[]

  @@unique([accountId, amazonOrderId, orderSource])
  @@index([accountId, orderStatus])
  @@index([accountId, workflowStatus])
  @@index([accountId, orderSource])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId     String
  asin            String?
  sellerSku       String?
  title           String?
  quantityOrdered Int      @default(1)
  quantityShipped Int      @default(0)
  itemPrice       Decimal? @db.Decimal(12, 2)
  itemTax         Decimal? @db.Decimal(12, 2)
  shippingPrice   Decimal? @db.Decimal(12, 2)
  imageUrl        String?
  isTransparency    Boolean  @default(false)
  transparencyCodes String[] @default([])
  bmSerials         String[] @default([]) // BackMarket serial/IMEI numbers (one per unit)
  gradeId           String?
  grade             Grade?   @relation(fields: [gradeId], references: [id], onDelete: SetNull)

  reservations         OrderInventoryReservation[]
  serialAssignments    OrderSerialAssignment[]
  marketplaceRMAItems  MarketplaceRMAItem[]

  @@unique([orderId, orderItemId])
  @@index([orderId])
  @@map("order_items")
}

model OrderInventoryReservation {
  id          String        @id @default(cuid())
  orderId     String
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId String
  orderItem   OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  productId   String
  product     Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  locationId  String
  location    Location      @relation(fields: [locationId], references: [id], onDelete: Restrict)
  gradeId     String?
  grade       Grade? @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  qtyReserved Int
  reservedAt  DateTime      @default(now())

  @@index([orderId])
  @@map("order_inventory_reservations")
}

// ─── Order Labels ─────────────────────────────────────────────────────────────
// Stores the shipping label purchased for an order so it can be reprinted later.

model OrderLabel {
  id             String   @id @default(cuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  trackingNumber String
  labelData      String   @db.Text // base64-encoded PDF/PNG
  labelFormat    String   @default("pdf")
  shipmentCost   Decimal? @db.Decimal(12, 2)
  insuranceCost  Decimal? @db.Decimal(12, 2)
  carrier        String?
  serviceCode    String?
  isTest         Boolean  @default(false)
  ssShipmentId   String?  // ShipStation shipmentId (V1 int or V2 "se-xxx") — required to void the label
  createdAt      DateTime @default(now())

  @@map("order_labels")
}

// ─── Order Serial Assignments ─────────────────────────────────────────────────
// Tracks which specific serial numbers were assigned (sold) for each order item.

model OrderSerialAssignment {
  id                String          @id @default(cuid())
  orderId           String
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItemId       String
  orderItem         OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  inventorySerialId String          // historically a serial can appear on multiple orders
  inventorySerial   InventorySerial @relation(fields: [inventorySerialId], references: [id], onDelete: Restrict)
  assignedAt        DateTime        @default(now())

  @@index([orderId])
  @@map("order_serial_assignments")
}

model OrderSyncJob {
  id           String             @id @default(cuid())
  accountId    String
  account      AmazonAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  source       String             @default("amazon") // "amazon" | "backmarket"
  trigger      String             @default("manual")  // "cron" | "manual"
  status       OrderSyncJobStatus @default(PENDING)
  totalFound   Int                @default(0)
  totalSynced  Int                @default(0)
  errorMessage String?
  startedAt    DateTime           @default(now())
  completedAt  DateTime?

  @@map("order_sync_jobs")
}

enum OrderSyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ─── ShipStation ──────────────────────────────────────────────────────────────

model ShipStationAccount {
  id           String   @id @default(cuid())
  name         String   @default("ShipStation")
  apiKeyEnc    String
  apiSecretEnc String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // V2 / ShipEngine API fields
  v2ApiKeyEnc     String? // ShipEngine API key (separate from V1 key)
  amazonCarrierId String? // e.g. se-5013604

  // Internal V3 API fields — kept for reference but no longer used
  internalJwtEnc    String?
  internalJwtExp    DateTime?
  partition         Int?
  internalSellerId  String?
  internalUserId    String?
  defaultShipFromId String?

  @@map("shipstation_accounts")
}

// ─── UPS Credentials ──────────────────────────────────────────────────────────

model UpsCredential {
  id               String   @id @default(cuid())
  nickname         String   @default("Primary")
  clientIdEnc      String
  clientSecretEnc  String
  accountNumberEnc String?  // UPS account number (shipper number) used for billing labels
  isDefault        Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  returnLabels     ReturnLabel[]

  @@map("ups_credentials")
}

model UpsBuyShippingCredential {
  id               String    @id @default(cuid())
  accountNumberEnc String
  accountZipEnc    String
  shipFromCityEnc  String
  shipFromZipEnc   String
  countryEnc       String
  upsUsernameEnc   String
  upsPasswordEnc   String
  isActive         Boolean   @default(true)
  lastLinkedAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("ups_buy_shipping_credentials")
}

// ─── FedEx Credentials ───────────────────────────────────────────────────────

model FedexCredential {
  id               String   @id @default(cuid())
  clientIdEnc      String
  clientSecretEnc  String
  accountNumberEnc String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("fedex_credentials")
}

model FedexShippingCredential {
  id                    String   @id @default(cuid())
  clientIdEnc           String
  clientSecretEnc       String
  accountNumberEnc      String
  testClientIdEnc       String?
  testClientSecretEnc   String?
  testAccountNumberEnc  String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("fedex_shipping_credentials")
}

model BackMarketCredential {
  id         String   @id @default(cuid())
  apiKeyEnc  String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("backmarket_credentials")
}

// ─── Shipping Presets ─────────────────────────────────────────────────────────
// Named package configs (carrier, weight, dimensions) that can be bulk-applied
// to orders to fetch a ShipStation rate and pre-fill the shipping column.

model ShippingPreset {
  id           String   @id @default(cuid())
  name         String
  carrierCode  String
  serviceCode  String?
  packageCode  String?
  weightValue  Float
  weightUnit   String   @default("ounces")
  dimLength    Float?
  dimWidth     Float?
  dimHeight    Float?
  dimUnit      String   @default("inches")
  confirmation      String?
  insuredValue      Float?    // declared value in USD (e.g. 150.00)
  insuranceProvider String?   // 'parcelguard' | 'carrier' | null (null = none)
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orders Order[]

  @@map("shipping_presets")
}

// ─── Package Presets ──────────────────────────────────────────────────────────
// Like ShippingPresets but without a carrier — used for bulk rate-shopping
// across all available carriers (cheapest wins).

model PackagePreset {
  id           String   @id @default(cuid())
  name         String
  packageCode  String?
  weightValue  Float
  weightUnit   String   @default("ounces")
  dimLength    Float?
  dimWidth     Float?
  dimHeight    Float?
  dimUnit      String   @default("inches")
  confirmation String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products     Product[] @relation("ProductDefaultPackagePreset")
  orders       Order[]

  @@map("package_presets")
}

// ─── Label Batches ────────────────────────────────────────────────────────────
// Tracks background bulk label-purchase jobs so progress can be polled after
// the browser is closed.

enum LabelBatchStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model LabelBatch {
  id          String           @id @default(cuid())
  status      LabelBatchStatus @default(PENDING)
  isTest      Boolean          @default(false)
  totalOrders Int
  completed   Int              @default(0)
  failed      Int              @default(0)
  createdAt   DateTime         @default(now())
  completedAt DateTime?
  items       LabelBatchItem[]

  @@map("label_batches")
}

model LabelBatchItem {
  id        String           @id @default(cuid())
  batchId   String
  batch     LabelBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  orderId   String
  order     Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    LabelBatchStatus @default(PENDING)
  error     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("label_batch_items")
}

// ─── Vendors ──────────────────────────────────────────────────────────────────

model Vendor {
  id           String   @id @default(cuid())
  vendorNumber Int      @unique @default(autoincrement())
  name         String
  contact      String?
  phone        String?
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchaseOrders   PurchaseOrder[]
  vendorRMAs       VendorRMA[]
  ledgerEntries    VendorLedgerEntry[]
  inventorySerials InventorySerial[]
  users            User[]

  @@map("vendors")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id             String   @id @default(cuid())
  description    String
  sku            String   @unique
  isSerializable Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  archivedAt             DateTime? // null = active, non-null = archived

  defaultPackagePresetId String?
  defaultPackagePreset   PackagePreset? @relation("ProductDefaultPackagePreset", fields: [defaultPackagePresetId], references: [id], onDelete: SetNull)

  poLines                PurchaseOrderLine[]
  receiptLines           POReceiptLine[]
  inventoryItems         InventoryItem[]
  inventorySerials       InventorySerial[]
  fromSerialHistory      SerialHistory[]                  @relation("SHFromProduct")
  toSerialHistory        SerialHistory[]                  @relation("SHToProduct")
  salesOrderItems        SalesOrderItem[]
  vendorRMAItems         VendorRMAItem[]
  customerRMAItems       CustomerRMAItem[]
  customerRMASerials     CustomerRMASerial[]
  orderReservations      OrderInventoryReservation[]
  salesOrderReservations SalesOrderInventoryReservation[]
  marketplaceSkus        ProductGradeMarketplaceSku[]
  marketplaceRMAItems    MarketplaceRMAItem[]
  fbaReservations        FbaInventoryReservation[]
  fbaReturnReceipts      FbaReturnReceipt[]

  @@map("products")
}

// ─── Grades (global / store-level) ────────────────────────────────────────────

model Grade {
  id          String   @id @default(cuid())
  grade       String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  marketplaceSkus        ProductGradeMarketplaceSku[]
  inventorySerials       InventorySerial[]
  inventoryItems         InventoryItem[]
  orderReservations      OrderInventoryReservation[]
  salesOrderReservations SalesOrderInventoryReservation[]
  marketplaceRMASerials  MarketplaceRMASerial[]
  customerRMASerials     CustomerRMASerial[]
  purchaseOrderLines     PurchaseOrderLine[]
  orderItems             OrderItem[]
  salesOrderItems        SalesOrderItem[]   @relation("GradeSalesOrderItems")
  fbaReservations        FbaInventoryReservation[]
  fbaReturnReceipts      FbaReturnReceipt[]

  @@map("grades")
}

model ProductGradeMarketplaceSku {
  id          String        @id @default(cuid())
  productId   String
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  gradeId     String?
  grade       Grade? @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  marketplace String // "amazon" | "backmarket" | "wholesale"
  accountId   String? // null = applies to all accounts for that marketplace
  sellerSku   String
  syncQty     Boolean       @default(false)
  maxQty      Int?          // null = no cap; when set, pushed qty is min(available, maxQty)
  isDefaultSku Boolean      @default(false) // true = receives the 1 unit when low-stock buffer applies
  isSynced    Boolean       @default(false) // true = came from marketplace sync
  fnsku       String?       // Fulfillment Network SKU (for FBA shipments)
  lastPushedQty Int?        // last quantity successfully pushed to marketplace
  lastPushedAt  DateTime?   // when last push succeeded
  createdAt   DateTime      @default(now())

  marketplaceListing MarketplaceListing?
  fbaShipmentItems   FbaShipmentItem[]
  pricingStrategyAssignments PricingStrategyMsku[]

  @@unique([sellerSku, marketplace, accountId])
  @@map("product_grade_marketplace_skus")
}

// ─── Marketplace Listings (synced from marketplaces) ──────────────────────────

model MarketplaceListing {
  id                 String    @id @default(cuid())
  marketplace        String    // "amazon" | "backmarket"
  sellerSku          String
  title              String?
  accountId          String?   // Amazon account ID or null for BM
  fulfillmentChannel String?   // "MFN" | "FBA" (Amazon only)
  externalId         String?   // BM listing_id or other marketplace-specific ID
  lastSyncedAt       DateTime  @default(now())
  createdAt          DateTime  @default(now())

  // Link to the mapping (null = unmapped)
  mskuId        String?   @unique
  msku          ProductGradeMarketplaceSku? @relation(fields: [mskuId], references: [id], onDelete: SetNull)

  @@unique([marketplace, sellerSku, accountId])
  @@map("marketplace_listings")
}

// ─── Purchase Orders ──────────────────────────────────────────────────────────

enum POStatus {
  OPEN
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id        String   @id @default(cuid())
  poNumber  Int      @unique
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  date      DateTime
  notes     String?
  status    POStatus @default(OPEN)
  vendorInvoiceBase64   String?  @db.Text
  vendorInvoiceFilename String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines         PurchaseOrderLine[]
  receipts      POReceipt[]
  serialHistory SerialHistory[]
  ledgerEntry   VendorLedgerEntry?

  @@index([vendorId])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  gradeId         String?
  grade           Grade? @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  costCodeId      String?
  costCode        CostCode? @relation(fields: [costCodeId], references: [id], onDelete: SetNull)
  qty             Int           @default(1)
  unitCost        Decimal       @db.Decimal(12, 2)
  createdAt       DateTime      @default(now())

  receiptLines POReceiptLine[]

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([gradeId])
  @@index([costCodeId])
  @@map("purchase_order_lines")
}

// ─── Vendor Ledger ───────────────────────────────────────────────────────────

enum LedgerEntryType {
  DEBIT
  CREDIT
}

model VendorLedgerEntry {
  id              String          @id @default(cuid())
  vendorId        String
  vendor          Vendor          @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  type            LedgerEntryType
  amount          Decimal         @db.Decimal(12, 2)
  description     String?
  vendorInvoiceNo String?
  purchaseOrderId String?         @unique
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  fileBase64      String?         @db.Text
  fileFilename    String?
  createdAt       DateTime        @default(now())
  adjustments     VendorLedgerAdjustment[]

  @@index([vendorId])
  @@map("vendor_ledger_entries")
}

model VendorLedgerAdjustment {
  id      String            @id @default(cuid())
  entryId String
  entry   VendorLedgerEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  label   String
  amount  Decimal           @db.Decimal(12, 2)

  @@index([entryId])
  @@map("vendor_ledger_adjustments")
}

// ─── MFN Returns ─────────────────────────────────────────────────────────────

model MFNReturn {
  id                String        @id @default(cuid())
  accountId         String
  account           AmazonAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orderId           String
  orderDate         DateTime? // Date the original order was placed (from flat-file report)
  rmaId             String? // Amazon RMA number
  trackingNumber    String? // Return shipping label tracking number
  returnValue       Decimal?      @db.Decimal(12, 2)
  currency          String        @default("USD")
  returnDate        DateTime? // Date the return was requested / initiated
  asin              String?
  sku               String?
  title             String?
  quantity          Int?
  returnReason      String?
  returnStatus      String?
  resolution        String?    // "Refund", "Replacement", etc.
  inPolicy          String?    // "yes"/"no" — within Amazon return window
  isPrime           String?    // "yes"/"no"
  aToZClaim         String?    // A-to-Z Guarantee claim value
  returnType        String?    // Return type classification
  labelType         String?    // Prepaid, seller-provided, etc.
  labelCost         Decimal?   @db.Decimal(12, 2)
  labelPaidBy       String?    // "Amazon" or "Seller"
  returnCarrier     String?    // UPS, USPS, FedEx, etc.
  merchantRmaId     String?    // Seller's own RMA ID
  returnDeliveryDate DateTime? // When the return was physically delivered back
  orderAmount       Decimal?   @db.Decimal(12, 2)
  orderQuantity     Int?
  refundedAmount    Decimal?   @db.Decimal(12, 2)
  safetClaimId      String?
  safetClaimState   String?
  safetActionReason String?
  safetClaimCreatedAt DateTime?
  safetReimbursement Decimal?  @db.Decimal(12, 2)
  invoiceNumber     String?
  orderItemId       String?
  // Find My iPhone / iCloud Lock check
  fmiStatus         String?   // "ON", "OFF", or error message
  fmiCheckedAt      DateTime?

  // Live carrier tracking status (fetched on demand)
  carrierStatus     String?
  deliveredAt       DateTime? // Actual delivery date from carrier (set when status = Delivered)
  estimatedDelivery DateTime? // Estimated delivery date from carrier (set when in transit)
  trackingUpdatedAt DateTime?
  importedAt        DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([accountId])
  @@index([accountId, orderId])
  @@index([returnDate])
  @@map("mfn_returns")
}

model MFNReturnSyncJob {
  id            String              @id @default(cuid())
  accountId     String
  account       AmazonAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  status        MFNReturnSyncStatus @default(IN_PROGRESS)
  startDate     DateTime
  endDate       DateTime
  totalFound    Int                 @default(0)
  totalUpserted Int                 @default(0)
  errorMessage  String?
  startedAt     DateTime            @default(now())
  completedAt   DateTime?

  @@map("mfn_return_sync_jobs")
}

enum MFNReturnSyncStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

// ─── Warehouses & Locations ───────────────────────────────────────────────────

model Warehouse {
  id           String   @id @default(cuid())
  name         String
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  countryCode  String   @default("US")
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  locations    Location[]
  fbaShipments FbaShipment[]

  @@map("warehouses")
}

model Location {
  id              String    @id @default(cuid())
  name            String
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  isFinishedGoods Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  receiptLines           POReceiptLine[]
  inventoryItems         InventoryItem[]
  inventorySerials       InventorySerial[]
  serialHistory          SerialHistory[]                  @relation("SHToLocation")
  fromSerialHistory      SerialHistory[]                  @relation("SHFromLocation")
  orderReservations      OrderInventoryReservation[]
  salesOrderReservations SalesOrderInventoryReservation[]
  marketplaceRMASerials  MarketplaceRMASerial[]
  customerRMASerials     CustomerRMASerial[]
  fbaReservations        FbaInventoryReservation[]
  clientLocationAccess   ClientLocationAccess[]
  fbaReturnReceipts      FbaReturnReceipt[]

  @@unique([warehouseId, name])
  @@index([warehouseId])
  @@map("locations")
}

// ─── PO Receipts ──────────────────────────────────────────────────────────────

model POReceipt {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receivedAt      DateTime      @default(now())
  notes           String?

  lines         POReceiptLine[]
  serialHistory SerialHistory[]

  @@index([purchaseOrderId])
  @@map("po_receipts")
}

model POReceiptLine {
  id                  String            @id @default(cuid())
  receiptId           String
  receipt             POReceipt         @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  purchaseOrderLineId String
  purchaseOrderLine   PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Restrict)
  productId           String
  product             Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  qtyReceived         Int
  locationId          String
  location            Location          @relation(fields: [locationId], references: [id], onDelete: Restrict)

  serials InventorySerial[]

  @@index([receiptId])
  @@index([purchaseOrderLineId])
  @@index([productId])
  @@map("po_receipt_lines")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model InventoryItem {
  id         String        @id @default(cuid())
  productId  String
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId String
  location   Location      @relation(fields: [locationId], references: [id], onDelete: Restrict)
  gradeId    String?
  grade      Grade? @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  qty        Int           @default(0)
  updatedAt  DateTime      @updatedAt

  @@unique([productId, locationId, gradeId])
  @@index([productId])
  @@index([locationId])
  @@map("inventory_items")
}

model InventorySerial {
  id            String         @id @default(cuid())
  serialNumber  String
  productId     String
  product       Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  locationId    String
  location      Location       @relation(fields: [locationId], references: [id], onDelete: Restrict)
  gradeId       String?
  grade         Grade?  @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  receiptLineId String?
  receiptLine   POReceiptLine? @relation(fields: [receiptLineId], references: [id])
  vendorId      String?
  vendor        Vendor?        @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  status        SerialStatus   @default(IN_STOCK)
  note          String?
  binLocation   String?
  unitCost      Decimal?       @db.Decimal(12, 2)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  history                SerialHistory[]
  orderAssignments       OrderSerialAssignment[]
  salesOrderAssignment   SalesOrderSerialAssignment?
  fbaShipmentAssignment  FbaShipmentSerialAssignment?
  marketplaceRMASerials  MarketplaceRMASerial[]
  customerRMASerials     CustomerRMASerial[]
  fbaReturnReceipts      FbaReturnReceipt[]

  @@unique([productId, serialNumber])
  @@index([productId, locationId])
  @@index([locationId])
  @@index([vendorId])
  @@map("inventory_serials")
}

enum SerialStatus {
  IN_STOCK
  OUT_OF_STOCK
}

// ─── Serial Number History ────────────────────────────────────────────────────

model SerialHistory {
  id                String          @id @default(cuid())
  inventorySerialId String
  inventorySerial   InventorySerial @relation(fields: [inventorySerialId], references: [id], onDelete: Cascade)
  eventType         SerialEventType
  // PO Receipt context (populated for PO_RECEIPT events)
  receiptId         String?
  receipt           POReceipt?      @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  // Sale context (populated for SALE events)
  orderId           String?
  order             Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  // Wholesale sale context (populated for wholesale SALE events)
  salesOrderId      String?
  salesOrder        SalesOrder?     @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  // FBA shipment context (populated for FBA_SHIPMENT events)
  fbaShipmentId     String?
  fbaShipment       FbaShipment?    @relation(fields: [fbaShipmentId], references: [id], onDelete: SetNull)
  locationId        String?
  location          Location?       @relation("SHToLocation", fields: [locationId], references: [id], onDelete: SetNull)
  fromLocationId    String?
  fromLocation      Location?       @relation("SHFromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  fromProductId     String?
  fromProduct       Product?        @relation("SHFromProduct", fields: [fromProductId], references: [id], onDelete: SetNull)
  toProductId       String?
  toProduct         Product?        @relation("SHToProduct", fields: [toProductId], references: [id], onDelete: SetNull)
  notes             String?
  userId            String?
  user              User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())

  @@index([inventorySerialId])
  @@index([receiptId])
  @@index([orderId])
  @@map("serial_history")
}

enum SerialEventType {
  PO_RECEIPT
  LOCATION_MOVE
  SKU_CONVERSION
  SALE
  ASSIGNED
  UNASSIGNED
  VOID_REINSTATE
  BIN_ASSIGNED
  NOTE_ADDED
  MANUAL_ADD
  MANUAL_REMOVE
  MANUAL_FBA
  MIGRATION
  MP_RMA_RETURN
  FBA_SHIPMENT
  VENDOR_RMA_SHIPPED
  WHOLESALE_RMA_RETURN
  GRADE_CHANGE
  FBA_RETURN
}

// ─── RMA (Return Merchandise Authorization) ───────────────────────────────────
// Internal return requests created by staff when a customer returns an order.
// Separate from Amazon's MFN return tracking — this is our own RMA workflow.

model RMA {
  id            String    @id @default(cuid())
  rmaNumber     String    @unique
  amazonOrderId String
  reason        String
  status        RMAStatus @default(REQUESTED)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items RMAItem[]

  @@index([amazonOrderId])
  @@map("rmas")
}

model RMAItem {
  id                  String    @id @default(cuid())
  rmaId               String
  rma                 RMA       @relation(fields: [rmaId], references: [id], onDelete: Cascade)
  orderItemId         String
  sellerSku           String?
  asin                String?
  title               String?
  quantityReturned    Int       @default(1)
  condition           String    @default("Used - Good")
  restockToInventory  Boolean   @default(false)
  restockedLocationId String?
  restockedQty        Int?
  restockedAt         DateTime?
  createdAt           DateTime  @default(now())

  @@index([rmaId])
  @@map("rma_items")
}

enum RMAStatus {
  REQUESTED
  SHIPPED_BACK
  RECEIVED
  RESTOCKED
  CLOSED
}

// ─── Wholesale ────────────────────────────────────────────────────────────────

enum AddressType {
  SHIPPING
  BILLING
}

enum SalesOrderStatus {
  PENDING_APPROVAL
  DRAFT
  CONFIRMED
  INVOICED
  PARTIALLY_PAID
  PAID
  VOID
}

enum PaymentMethod {
  CHECK
  ACH
  WIRE
  CREDIT_CARD
  CASH
  ZELLE
  OTHER
}

enum WholesalePaymentTerms {
  NET_15
  NET_30
  NET_60
  NET_90
  DUE_ON_RECEIPT
}

enum SalesFulfillmentStatus {
  PENDING // Created, awaiting processing
  PROCESSING // Inventory pulled, ready to ship
  SHIPPED // Shipped — carrier + tracking recorded
  CANCELLED
}

model WholesaleCustomer {
  id              String                @id @default(cuid())
  companyName     String
  contactName     String?
  phone           String?
  email           String?
  website         String?
  taxExempt       Boolean               @default(false)
  taxId           String?
  taxRate         Decimal               @default(0) @db.Decimal(6, 4)
  creditLimit     Decimal?              @db.Decimal(12, 2)
  paymentTerms    WholesalePaymentTerms @default(NET_30)
  defaultDiscount Decimal               @default(0) @db.Decimal(5, 2)
  notes           String?
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  addresses    CustomerAddress[]
  salesOrders  SalesOrder[]
  payments     WholesalePayment[]
  customerRmas CustomerRMA[]
  creditMemos  WholesaleCreditMemo[]

  @@index([companyName])
  @@map("wholesale_customers")
}

model CustomerAddress {
  id           String            @id @default(cuid())
  customerId   String
  customer     WholesaleCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type         AddressType
  label        String            @default("Main")
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  postalCode   String
  country      String            @default("US")
  isDefault    Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([customerId])
  @@map("customer_addresses")
}

model SalesOrder {
  id                String                 @id @default(cuid())
  orderNumber       String                 @unique
  customerId        String
  customer          WholesaleCustomer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status            SalesOrderStatus       @default(PENDING_APPROVAL)
  orderDate         DateTime               @default(now())
  dueDate           DateTime?
  shippingAddress   Json?
  billingAddress    Json?
  subtotal          Decimal                @default(0) @db.Decimal(12, 2)
  discountPct       Decimal                @default(0) @db.Decimal(5, 2)
  discountAmt       Decimal                @default(0) @db.Decimal(12, 2)
  taxRate           Decimal                @default(0) @db.Decimal(6, 4)
  taxAmt            Decimal                @default(0) @db.Decimal(12, 2)
  shippingCost      Decimal                @default(0) @db.Decimal(12, 2)
  total             Decimal                @default(0) @db.Decimal(12, 2)
  paidAmount        Decimal                @default(0) @db.Decimal(12, 2)
  balance           Decimal                @default(0) @db.Decimal(12, 2)
  customerPoNumber  String?
  notes             String?
  internalNotes     String?
  // Fulfillment workflow (parallel to accounting status)
  fulfillmentStatus SalesFulfillmentStatus @default(PENDING)
  processedAt       DateTime?
  shipCarrier       String?
  shipTracking      String?
  shippedAt         DateTime?
  invoiceNumber     String?                @unique
  invoicedAt        DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  items                  SalesOrderItem[]
  allocations            PaymentAllocation[]
  creditMemoAllocations  CreditMemoAllocation[]
  serialAssignments      SalesOrderSerialAssignment[]
  inventoryReservations  SalesOrderInventoryReservation[]
  customerRMASerials     CustomerRMASerial[]
  serialHistory          SerialHistory[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([fulfillmentStatus])
  @@map("sales_orders")
}

model SalesOrderItem {
  id          String     @id @default(cuid())
  orderId     String
  order       SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  gradeId     String?
  grade       Grade?     @relation("GradeSalesOrderItems", fields: [gradeId], references: [id], onDelete: SetNull)
  sku         String?
  title       String
  description String?
  quantity    Decimal    @db.Decimal(12, 4)
  unitPrice   Decimal    @db.Decimal(12, 2)
  discount    Decimal    @default(0) @db.Decimal(5, 2)
  total       Decimal    @db.Decimal(12, 2)
  taxable        Boolean    @default(true)
  isInvoiceAddon Boolean    @default(false)
  createdAt      DateTime   @default(now())

  reservations SalesOrderInventoryReservation[]

  @@index([orderId])
  @@map("sales_order_items")
}

// Tracks inventory reserved for each wholesale (SalesOrder) item
model SalesOrderInventoryReservation {
  id               String         @id @default(cuid())
  salesOrderId     String
  salesOrder       SalesOrder     @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  salesOrderItemId String
  salesOrderItem   SalesOrderItem @relation(fields: [salesOrderItemId], references: [id], onDelete: Cascade)
  productId        String
  product          Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  locationId       String
  location         Location       @relation(fields: [locationId], references: [id], onDelete: Restrict)
  gradeId          String?
  grade            Grade?  @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  qtyReserved      Int
  reservedAt       DateTime       @default(now())

  @@index([salesOrderId])
  @@map("sales_order_inventory_reservations")
}

// Tracks which serial numbers were picked for a wholesale (SalesOrder) shipment
model SalesOrderSerialAssignment {
  id               String          @id @default(cuid())
  salesOrderId     String
  salesOrder       SalesOrder      @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  salesOrderItemId String? // which line item this serial belongs to (optional)
  serialId         String          @unique // one active assignment per serial
  inventorySerial  InventorySerial @relation(fields: [serialId], references: [id], onDelete: Restrict)
  assignedAt       DateTime        @default(now())

  @@index([salesOrderId])
  @@map("sales_order_serial_assignments")
}

model WholesalePayment {
  id            String            @id @default(cuid())
  paymentNumber String            @unique @default("")
  customerId    String
  customer      WholesaleCustomer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  paymentDate   DateTime
  amount      Decimal           @db.Decimal(12, 2)
  method      PaymentMethod
  reference   String?
  memo        String?
  unallocated Decimal           @default(0) @db.Decimal(12, 2)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  allocations PaymentAllocation[]

  @@index([customerId])
  @@map("wholesale_payments")
}

model WholesaleCreditMemo {
  id               String            @id @default(cuid())
  memoNumber       String            @unique
  customerId       String
  customer         WholesaleCustomer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  rmaId            String?           @unique
  rma              CustomerRMA?      @relation(fields: [rmaId], references: [id], onDelete: Restrict)
  subtotal         Decimal           @db.Decimal(12, 2)
  restockingFee    Decimal           @default(0) @db.Decimal(12, 2)
  restockingReason String?
  total            Decimal           @db.Decimal(12, 2)
  status           String            @default("UNAPPLIED") // UNAPPLIED, PARTIALLY_APPLIED, APPLIED
  unallocated      Decimal           @default(0) @db.Decimal(12, 2)
  notes            String?
  memo             String?
  description      String?
  createdAt        DateTime          @default(now())

  allocations CreditMemoAllocation[]

  @@index([customerId])
  @@map("wholesale_credit_memos")
}

model CreditMemoAllocation {
  id           String              @id @default(cuid())
  creditMemoId String
  creditMemo   WholesaleCreditMemo @relation(fields: [creditMemoId], references: [id], onDelete: Cascade)
  orderId      String
  order        SalesOrder          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  amount       Decimal             @db.Decimal(12, 2)
  createdAt    DateTime            @default(now())

  @@index([creditMemoId])
  @@index([orderId])
  @@map("credit_memo_allocations")
}

model PaymentAllocation {
  id        String           @id @default(cuid())
  paymentId String
  payment   WholesalePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  orderId   String
  order     SalesOrder       @relation(fields: [orderId], references: [id], onDelete: Restrict)
  amount    Decimal          @db.Decimal(12, 2)
  createdAt DateTime         @default(now())

  @@index([paymentId])
  @@index([orderId])
  @@map("payment_allocations")
}

// ─── Vendor RMA ───────────────────────────────────────────────────────────────

enum VendorRMAStatus {
  AWAITING_VENDOR_APPROVAL
  APPROVED_TO_RETURN
  SHIPPED_AWAITING_CREDIT
  CREDIT_RECEIVED
}

enum CustomerRMAStatus {
  PENDING
  RECEIVED
  INSPECTED
  REFUNDED
  REJECTED
}

model CustomerRMA {
  id           String            @id @default(cuid())
  rmaNumber    String            @unique
  customerId   String
  customer     WholesaleCustomer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status       CustomerRMAStatus @default(PENDING)
  reason       String?
  notes        String?
  creditAmount Decimal?          @db.Decimal(12, 2)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  items      CustomerRMAItem[]
  serials    CustomerRMASerial[]
  creditMemo WholesaleCreditMemo?

  @@index([customerId])
  @@index([status])
  @@map("customer_rmas")
}

model CustomerRMAItem {
  id        String      @id @default(cuid())
  rmaId     String
  rma       CustomerRMA @relation(fields: [rmaId], references: [id], onDelete: Cascade)
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int         @default(1)
  unitPrice Decimal?    @db.Decimal(12, 2)
  condition String?
  notes     String?
  createdAt DateTime    @default(now())

  @@index([rmaId])
  @@map("customer_rma_items")
}

model CustomerRMASerial {
  id                 String           @id @default(cuid())
  rmaId              String
  rma                CustomerRMA      @relation(fields: [rmaId], references: [id], onDelete: Cascade)
  inventorySerialId  String
  inventorySerial    InventorySerial  @relation(fields: [inventorySerialId], references: [id], onDelete: Restrict)
  productId          String
  product            Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  gradeId            String?
  grade              Grade?           @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  serialNumber       String           // denormalized for display/PDF
  salePrice          Decimal?         @db.Decimal(12, 2)
  salesOrderId       String?
  salesOrder         SalesOrder?      @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  soldAt             DateTime?        // SalesOrder.shippedAt snapshot
  returnReason       String
  receivedAt         DateTime?
  receivedLocationId String?
  receivedLocation   Location?        @relation(fields: [receivedLocationId], references: [id], onDelete: SetNull)
  notes              String?
  createdAt          DateTime         @default(now())

  @@unique([rmaId, inventorySerialId])
  @@index([rmaId])
  @@index([inventorySerialId])
  @@map("customer_rma_serials")
}

model VendorRMA {
  id                   String          @id @default(cuid())
  rmaNumber            String          @unique // "VRMA-0001"
  vendorId             String
  vendor               Vendor          @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  status               VendorRMAStatus @default(AWAITING_VENDOR_APPROVAL)
  vendorApprovalNumber String?
  carrier              String?
  trackingNumber       String?
  carrierStatus        String?
  deliveredAt          DateTime?
  estimatedDelivery    DateTime?
  trackingUpdatedAt    DateTime?
  notes                String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  items VendorRMAItem[]

  @@index([vendorId])
  @@index([status])
  @@map("vendor_rmas")
}

model VendorRMAItem {
  id        String    @id @default(cuid())
  rmaId     String
  rma       VendorRMA @relation(fields: [rmaId], references: [id], onDelete: Cascade)
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int       @default(1)
  unitCost  Decimal?  @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime  @default(now())

  serials VendorRMASerial[]

  @@index([rmaId])
  @@map("vendor_rma_items")
}

model VendorRMASerial {
  id           String        @id @default(cuid())
  rmaItemId    String
  rmaItem      VendorRMAItem @relation(fields: [rmaItemId], references: [id], onDelete: Cascade)
  serialNumber String
  scannedOutAt DateTime?
  createdAt    DateTime      @default(now())

  @@unique([rmaItemId, serialNumber])
  @@index([rmaItemId])
  @@map("vendor_rma_serials")
}

model ReturnLabel {
  id               String    @id @default(cuid())
  amazonOrderId    String?
  shipFromName     String
  shipFromAddress1 String
  shipFromCity     String
  shipFromState    String
  shipFromPostal   String
  shipFromCountry  String    @default("US")
  serviceCode      String
  serviceLabel     String?
  weightValue      Decimal   @db.Decimal(8, 2)
  weightUnit       String    @default("LBS")
  trackingNumber   String
  shipmentId       String
  labelData        String    @db.Text
  shipmentCost     Decimal?  @db.Decimal(12, 2)
  currency         String?   @default("USD")
  labelType        String    @default("RETURN")
  voided           Boolean   @default(false)
  voidedAt         DateTime?
  upsCredentialId  String?
  upsCredential    UpsCredential? @relation(fields: [upsCredentialId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())

  @@map("return_labels")
}

// ─── Marketplace Returns (MP-RMA) ────────────────────────────────────────────

enum MarketplaceRMAStatus {
  OPEN
  RECEIVED
}

model MarketplaceRMA {
  id        String               @id @default(cuid())
  rmaNumber String               @unique // "MP-RMA-0001"
  orderId   String
  order     Order                @relation(fields: [orderId], references: [id], onDelete: Restrict)
  status    MarketplaceRMAStatus @default(OPEN)
  notes     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  items MarketplaceRMAItem[]

  @@index([orderId])
  @@index([status])
  @@map("marketplace_rmas")
}

model MarketplaceRMAItem {
  id               String         @id @default(cuid())
  rmaId            String
  rma              MarketplaceRMA @relation(fields: [rmaId], references: [id], onDelete: Cascade)
  orderItemId      String
  orderItem        OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  productId        String?
  product          Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  sellerSku        String?
  asin             String?
  title            String?
  quantityReturned Int            @default(1)
  returnReason     String?
  createdAt        DateTime       @default(now())

  serials MarketplaceRMASerial[]

  @@index([rmaId])
  @@map("marketplace_rma_items")
}

model MarketplaceRMASerial {
  id                String           @id @default(cuid())
  rmaItemId         String
  rmaItem           MarketplaceRMAItem @relation(fields: [rmaItemId], references: [id], onDelete: Cascade)
  inventorySerialId String?
  inventorySerial   InventorySerial? @relation(fields: [inventorySerialId], references: [id], onDelete: SetNull)
  serialNumber      String
  receivedAt        DateTime?
  locationId        String?
  location          Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  gradeId           String?
  grade             Grade?    @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  note              String?

  @@index([rmaItemId])
  @@map("marketplace_rma_serials")
}

model RMAReturnReason {
  id        String   @id @default(cuid())
  label     String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rma_return_reasons")
}

// ─── Store Settings (singleton — one row) ────────────────────────────────────

model StoreSettings {
  id             String   @id @default("singleton")
  storeName      String   @default("Open Line Mobility")
  logoBase64     String?  @db.Text // data-URI (e.g. data:image/png;base64,…)
  phone          String?
  email          String?
  addressLine    String?  // street address
  city           String?
  state          String?
  zip            String?
  thankYouMsg    String   @default("Thank you for shopping with us!")
  primaryColor   String   @default("#14284B")
  accentColor    String   @default("#007ACC")
  defaultPrinter String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("store_settings")
}

// ─── SICKW IMEI Check ────────────────────────────────────────────────────────

model SickwCredential {
  id        String   @id @default(cuid())
  apiKeyEnc String   // AES-256-GCM encrypted via src/lib/crypto.ts
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sickw_credentials")
}

model SickwCheck {
  id          String   @id @default(cuid())
  imei        String
  serviceId   Int
  serviceName String
  status      String   // "success" | "error"
  result      String?  @db.Text // Full JSON response
  cost        Decimal? @db.Decimal(8, 4)
  createdAt   DateTime @default(now())

  @@index([imei])
  @@index([createdAt])
  @@map("sickw_checks")
}

// ─── Alerts ──────────────────────────────────────────────────────────────────

model Alert {
  id        String    @id @default(cuid())
  type      String    // e.g. "RETURN_ICLOUD_ON"
  title     String
  message   String    @db.Text
  metadata  Json?     // { returnId, orderId, serial, etc. }
  readAt     DateTime?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([readAt])
  @@index([archivedAt])
  @@index([createdAt])
  @@map("alerts")
}


enum FbaShipmentStatus {
  DRAFT
  SERIALIZED
  PLAN_CREATED
  PACKING_SET
  PLACEMENT_CONFIRMED
  TRANSPORT_CONFIRMED
  LABELS_READY
  SHIPPED
  CANCELLED
}


// ─── Cost Codes ─────────────────────────────────────────────────────────────

model CostCode {
  id        String   @id @default(cuid())
  name      String   @unique
  amount    Decimal  @db.Decimal(12, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrderLines PurchaseOrderLine[]

  @@map("cost_codes")
}

// ─── FBA Inbound Shipments ──────────────────────────────────────────────────

model FbaShipment {
  id                     String            @id @default(cuid())
  accountId              String
  account                AmazonAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  warehouseId            String?
  warehouse              Warehouse?        @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  status                 FbaShipmentStatus @default(DRAFT)
  shipmentNumber         String?           @unique // FBA-0001
  name                   String?           // user-provided label
  // Amazon API IDs
  inboundPlanId          String?
  shipmentId             String?
  shipmentConfirmationId String?
  packingOptionId        String?
  packingGroupId         String?
  placementOptionId      String?
  transportOptionId      String?
  deliveryWindowOptionId String?
  // Cost info
  placementFee           Decimal?          @db.Decimal(12, 2)
  shippingEstimate       Decimal?          @db.Decimal(12, 2)
  // Labels
  labelData              String?           // base64 PDF cached
  // Error tracking
  lastError              String?
  lastErrorAt            DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  items             FbaShipmentItem[]
  boxes             FbaShipmentBox[]
  reservations      FbaInventoryReservation[]
  serialAssignments FbaShipmentSerialAssignment[]
  serialHistory     SerialHistory[]
  fbaReturnReceipts FbaReturnReceipt[]

  @@index([accountId])
  @@index([status])
  @@map("fba_shipments")
}

model FbaShipmentItem {
  id        String                     @id @default(cuid())
  shipmentId String
  shipment  FbaShipment                @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  mskuId    String?
  msku      ProductGradeMarketplaceSku? @relation(fields: [mskuId], references: [id], onDelete: Restrict)
  sellerSku String
  fnsku     String
  asin      String?
  quantity  Int

  boxItems          FbaShipmentBoxItem[]
  serialAssignments FbaShipmentSerialAssignment[]

  @@index([shipmentId])
  @@map("fba_shipment_items")
}

model FbaShipmentBox {
  id         String      @id @default(cuid())
  shipmentId String
  shipment   FbaShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  boxNumber  Int
  weightLb   Decimal     @db.Decimal(8, 2)
  lengthIn   Decimal     @db.Decimal(8, 2)
  widthIn    Decimal     @db.Decimal(8, 2)
  heightIn       Decimal     @db.Decimal(8, 2)
  trackingNumber String?

  items FbaShipmentBoxItem[]

  @@unique([shipmentId, boxNumber])
  @@index([shipmentId])
  @@map("fba_shipment_boxes")
}

model FbaShipmentBoxItem {
  id             String          @id @default(cuid())
  boxId          String
  box            FbaShipmentBox  @relation(fields: [boxId], references: [id], onDelete: Cascade)
  shipmentItemId String
  shipmentItem   FbaShipmentItem @relation(fields: [shipmentItemId], references: [id], onDelete: Cascade)
  quantity       Int

  @@unique([boxId, shipmentItemId])
  @@map("fba_shipment_box_items")
}

model FbaInventoryReservation {
  id            String      @id @default(cuid())
  fbaShipmentId String
  fbaShipment   FbaShipment @relation(fields: [fbaShipmentId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  locationId    String
  location      Location    @relation(fields: [locationId], references: [id], onDelete: Restrict)
  gradeId       String?
  grade         Grade?      @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  qtyReserved   Int
  reservedAt    DateTime    @default(now())

  @@index([fbaShipmentId])
  @@map("fba_inventory_reservations")
}

// ─── FBA Shipment Serial Assignments ─────────────────────────────────────────
// Tracks which specific serial numbers were scanned out for each FBA shipment item.

model FbaShipmentSerialAssignment {
  id                String          @id @default(cuid())
  fbaShipmentId     String
  fbaShipment       FbaShipment     @relation(fields: [fbaShipmentId], references: [id], onDelete: Cascade)
  fbaShipmentItemId String
  fbaShipmentItem   FbaShipmentItem @relation(fields: [fbaShipmentItemId], references: [id], onDelete: Cascade)
  inventorySerialId String          @unique
  inventorySerial   InventorySerial @relation(fields: [inventorySerialId], references: [id], onDelete: Restrict)
  assignedAt        DateTime        @default(now())

  @@index([fbaShipmentId])
  @@map("fba_shipment_serial_assignments")
}

// ─── FBA Return Receipts ─────────────────────────────────────────────────────

model FbaReturnReceipt {
  id                String          @id @default(cuid())
  receiptNumber     String          @unique   // "FBA-RET-0001"
  inventorySerialId String
  inventorySerial   InventorySerial @relation(fields: [inventorySerialId], references: [id], onDelete: Restrict)
  productId         String
  product           Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  fbaShipmentId     String?
  fbaShipment       FbaShipment?    @relation(fields: [fbaShipmentId], references: [id], onDelete: SetNull)
  serialNumber      String          // denormalized
  sku               String          // denormalized
  gradeId           String?
  grade             Grade?          @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  previousGradeId   String?         // grade before regrade
  locationId        String
  location          Location        @relation(fields: [locationId], references: [id], onDelete: Restrict)
  note              String?
  receivedAt        DateTime        @default(now())
  receivedById      String?
  receivedBy        User?           @relation(fields: [receivedById], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())

  @@index([inventorySerialId])
  @@index([productId])
  @@map("fba_return_receipts")
}

// ─── Chat ────────────────────────────────────────────────────────────────────

model ChatConversation {
  id            String        @id @default(cuid())
  user1Id       String
  user1         User          @relation("ChatUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id       String
  user2         User          @relation("ChatUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  lastMessageAt DateTime?
  createdAt     DateTime      @default(now())
  messages      ChatMessage[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User             @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String?          @db.Text
  fileName       String?
  fileUrl        String?
  fileSize       Int?
  fileMimeType   String?
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

// ─── Free Replacements ──────────────────────────────────────────────────────

model FreeReplacement {
  id                    String    @id @default(cuid())
  accountId             String
  account               AmazonAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  replacementOrderId    String    @unique
  originalOrderId       String
  asin                  String
  title                 String
  shippedAt             DateTime?
  returnTrackingNumber  String?
  returnCarrierStatus   String?
  returnDeliveredAt     DateTime?
  trackingUpdatedAt     DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([accountId])
  @@index([originalOrderId])
  @@map("free_replacements")
}

// ─── Legacy Invoices ───────────────────────────────────────────────────────

model LegacyInvoice {
  id           String   @id @default(cuid())
  orderId      String
  orderDate    String
  customerName String   @default("")
  address      String   @default("")
  items        Json     @default("[]")
  tracking     Json     @default("[]")
  rawText      String   @default("")
  fileName     String   @default("")
  createdAt    DateTime @default(now())

  @@unique([orderId, fileName])
  @@map("legacy_invoices")
