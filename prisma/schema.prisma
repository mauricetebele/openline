// ─── Case Log ──────────────────────────────────────────────────────────────

enum CaseStatus {
  UNRESOLVED
  RESOLVED
}

model Case {
  id                   String       @id @default(cuid())
  caseNumber           Int          @unique @default(autoincrement())
  title                String
  description          String?      @db.Text
  status               CaseStatus   @default(UNRESOLVED)
  resolvedAt           DateTime?
  resolvedById         String?
  resolvedBy           User?        @relation("CaseResolvedBy", fields: [resolvedById], references: [id])
  resolutionNote       String?      @db.Text
  marketplaceCaseIds   Json?
  createdById          String
  createdBy            User         @relation("CaseCreatedBy", fields: [createdById], references: [id])
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  taggedUsers          CaseTaggedUser[]
  messages             CaseMessage[]

  @@index([status])
  @@map("cases")
}

model CaseTaggedUser {
  id       String @id @default(cuid())
  caseId   String
  case     Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  @@unique([caseId, userId])
  @@map("case_tagged_users")
}

model CaseMessage {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  body        String   @db.Text
  attachments Json?
  createdAt   DateTime @default(now())

  @@index([caseId])
  @@map("case_messages")
}

model ResolutionProviderVisibility {
  id                   String @id @default(cuid())
  resolutionProviderId String
  resolutionProvider   User   @relation("ResProviderVisibility", fields: [resolutionProviderId], references: [id], onDelete: Cascade)
  visibleUserId        String
  visibleUser          User   @relation("ResProviderVisibleTo", fields: [visibleUserId], references: [id], onDelete: Cascade)

  @@unique([resolutionProviderId, visibleUserId])
  @@map("resolution_provider_visibility")
}

// ─── OLI: Pricing Strategies ─────────────────────────────────────────────────

model PricingStrategy {
  id          String    @id @default(cuid())
  name        String
  marketplace String    // "amazon" | "backmarket"
  description String?   @db.Text
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  mskuAssignments PricingStrategyMsku[]
  @@map("pricing_strategies")
}

model PricingStrategyMsku {
  id         String   @id @default(cuid())
  strategyId String
  strategy   PricingStrategy            @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  mskuId     String
  msku       ProductGradeMarketplaceSku @relation(fields: [mskuId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  @@unique([strategyId, mskuId])
  @@index([strategyId])
  @@index([mskuId])
  @@map("pricing_strategy_mskus")
}

model OliSkuCache {
  sellerSku     String    @id
  asin          String?
  title         String?   @db.Text
  listingStatus String?
  price         Decimal?  @db.Decimal(10, 2)
  activeQty     Int       @default(0)
  activeSince   DateTime? // when listing last became BUYABLE (null = inactive)
  buyBoxPrice   Decimal?  @db.Decimal(10, 2)
  buyBoxWinner  String?
  lastSyncedAt  DateTime  @default(now())
  @@map("oli_sku_cache")
}
